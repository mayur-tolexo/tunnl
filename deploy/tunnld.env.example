# Copy to /etc/tunnl/tunnld.env on the VPS and fill in. Then: chmod 600 /etc/tunnl/tunnld.env

TUNNL_TOKEN=change-me-to-a-long-random-string
TUNNL_DOMAIN=shoplit.in
TUNNL_ACME_EMAIL=you@shoplit.in

# DNS-01 provider. Use acmedns for shoplit.in (GoDaddy's API is gated).
TUNNL_DNS_PROVIDER=acmedns
TUNNL_ACMEDNS_SERVER=http://127.0.0.1:8081
TUNNL_ACMEDNS_USERNAME=
TUNNL_ACMEDNS_PASSWORD=
TUNNL_ACMEDNS_SUBDOMAIN=

# Validate against the Let's Encrypt staging CA first. Comment out for real certs.
TUNNL_ACME_STAGING=1

# Optional
# TUNNL_MAX_TUNNELS=100
